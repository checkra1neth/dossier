[0.205, "o", "\r\n \u001b[36m📊 Analytics:\u001b[0m\r\n   /quick 0x<addr>          — portfolio snapshot ($0.01)\r\n   /research 0x<addr>       — deep research ($0.05)\r\n   /pnl 0x<addr>            — profit & loss ($0.02)\r\n   /defi 0x<addr>           — DeFi positions ($0.02)\r\n   /history 0x<addr>        — tx history ($0.02)\r\n   /nft 0x<addr>            — NFT portfolio ($0.02)\r\n   /compare 0x<a> 0x<b>     — compare wallets ($0.05)\r\n \u001b[36m💰 Wallet:\u001b[0m\r\n   /balance                 — your wallet balance (free)\r\n   /send <amt> <tok> to <addr> — send tokens ($0.01)\r\n   /swap <amt> <tok> to <tok>  — swap tokens ($0.01)\r\n"]
[0.000, "o", "   /bridge <amt> <tok> from <chain> to <chain> ($0.01)\r\n \u001b[36m👁️ Monitoring:\u001b[0m\r\n   /watch 0x<addr>          — watch wallet activity ($0.10)\r\n   /unwatch 0x<addr>        — stop watching (free)\r\n"]
